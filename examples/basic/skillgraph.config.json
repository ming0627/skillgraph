{
  "$schema": "../../schema/skillgraph.schema.json",
  "roots": [".agents/skills", ".claude/skills"],
  "outDir": "docs/skills",
  "canonicalRoots": [".agents/skills"],
  "wrapperRoots": [".claude/skills"],
  "privacy": {
    "includeEvidence": false,
    "redactTerms": ["ExampleCorp"]
  },
  "rules": {
    "stalePatterns": [
      {
        "id": "old-test-user",
        "pattern": "OLD_TEST_USER",
        "severity": "warn",
        "message": "Old test user reference should be removed."
      }
    ]
  }
}
