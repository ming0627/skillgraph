{
  "$schema": "../../schema/skillgraph.schema.json",
  "providers": [
    "github-copilot",
    "openai-codex",
    "cursor",
    "claude-code",
    "cline",
    "kilo-code",
    "agent-skills"
  ],
  "outDir": "docs/skills",
  "canonicalRoots": [".agents/skills"],
  "wrapperRoots": [".claude/skills"],
  "privacy": {
    "includeEvidence": false,
    "redactTerms": ["AcmeWorkspace"]
  },
  "rules": {
    "stalePatterns": [
      {
        "id": "old-test-user",
        "pattern": "OLD_TEST_USER",
        "severity": "warn",
        "message": "Old shared QA user reference should be removed."
      },
      {
        "id": "legacy-release-smoke",
        "pattern": "scripts/release/legacy-smoke.sh",
        "severity": "error",
        "message": "Release wrapper points to a retired smoke script."
      },
      {
        "id": "owner-role-drift",
        "regex": "\\bADMIN_ROLE\\b|\\badmin-only\\b",
        "severity": "warn",
        "message": "Use owner/member/invitee role language in the invite flow."
      }
    ]
  }
}
