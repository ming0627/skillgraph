{
  "name": "skillgraph",
  "version": "0.1.0",
  "description": "Map AI agent skills, wrappers, helper scripts, and workflow dependencies into Markdown, HTML, and JSON graphs.",
  "type": "module",
  "bin": {
    "skillgraph": "./bin/skillgraph.mjs"
  },
  "files": [
    "bin",
    "src",
    "schema",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "node --test",
    "check": "node --check bin/skillgraph.mjs && node --check src/skillgraph.mjs && node --test",
    "example:generate": "node bin/skillgraph.mjs generate --root examples/basic --config skillgraph.config.json",
    "example:check": "node bin/skillgraph.mjs check --root examples/basic --config skillgraph.config.json",
    "leak:scan": "node bin/skillgraph.mjs privacy-scan --terms-file docs/private-leak-terms.txt"
  },
  "keywords": [
    "ai-agents",
    "skills",
    "workflow",
    "mermaid",
    "knowledge-graph",
    "developer-tools",
    "claude-code",
    "codex"
  ],
  "author": "Sherman Lye",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  }
}
