{
  "name": "skillgraph",
  "version": "0.1.0",
  "description": "Map AI agent skills, wrappers, helper scripts, and workflow dependencies into Markdown, HTML, and JSON graphs.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ming0627/skillgraph.git"
  },
  "bugs": {
    "url": "https://github.com/ming0627/skillgraph/issues"
  },
  "homepage": "https://github.com/ming0627/skillgraph#readme",
  "bin": {
    "skillgraph": "./bin/skillgraph.mjs"
  },
  "files": [
    "bin",
    "src",
    "schema",
    "docs/*.md",
    "docs/assets",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "node --test",
    "check": "node --check bin/skillgraph.mjs && node --check src/skillgraph.mjs && node --test",
    "example:generate": "node bin/skillgraph.mjs generate --root examples/release-train-drift --config skillgraph.config.json",
    "example:check": "node bin/skillgraph.mjs check --root examples/release-train-drift --config skillgraph.config.json",
    "leak:scan": "node bin/skillgraph.mjs privacy-scan --terms-file docs/private-leak-terms.txt"
  },
  "keywords": [
    "ai-agents",
    "skills",
    "workflow",
    "mermaid",
    "knowledge-graph",
    "developer-tools",
    "ai-instructions",
    "agent-skills",
    "copilot",
    "cursor",
    "claude-code",
    "codex",
    "cline",
    "skill-drift"
  ],
  "author": "Sherman Lye",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  }
}
