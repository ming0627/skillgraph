{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ming0627/skillgraph/schema/skillgraph.schema.json",
  "title": "Skillgraph configuration",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "providers": {
      "type": "array",
      "items": {
        "enum": [
          "github-copilot",
          "cursor",
          "claude-code",
          "openai-codex",
          "cline",
          "augment-code",
          "kilo-code",
          "google-antigravity",
          "factory-ai",
          "agent-skills"
        ]
      },
      "description": "Provider presets to scan, sorted by public adoption signals."
    },
    "roots": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Additional directories or files that contain skill or instruction documents."
    },
    "outDir": {
      "type": "string",
      "description": "Directory where SKILLGRAPH.md, skillgraph.json, and skillgraph.html are written."
    },
    "canonicalRoots": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Roots treated as canonical skill sources."
    },
    "wrapperRoots": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Roots treated as mirror/wrapper skill sources."
    },
    "exclude": {
      "type": "array",
      "items": { "type": "string" }
    },
    "instructionExtensions": {
      "type": "array",
      "items": { "type": "string" },
      "description": "File extensions to scan inside provider/root directories."
    },
    "privacy": {
      "type": "object",
      "properties": {
        "includeEvidence": { "type": "boolean" },
        "redactTerms": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "rules": {
      "type": "object",
      "properties": {
        "stalePatterns": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "pattern": { "type": "string" },
              "regex": { "type": "string" },
              "flags": { "type": "string" },
              "severity": { "enum": ["info", "warn", "error"] },
              "message": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
